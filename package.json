{
  "name": "fleet-cli",
  "version": "0.0.0",
  "description": "Workspace management CLI for development projects",
  "module": "src/cli.ts",
  "type": "module",
  "bin": {
    "fleet": "dist/fleet"
  },
  "scripts": {
    "dev": "BUN_ENV=development bun run src/cli.ts",
    "test": "bun test",
    "build": "bun build src/cli.ts --compile --outfile dist/fleet --minify",
    "build:linux": "bun build src/cli.ts --compile --target=bun-linux-x64 --outfile dist/fleet-linux-x64",
    "build:windows": "bun build src/cli.ts --compile --target=bun-windows-x64 --outfile dist/fleet-windows-x64.exe",
    "build:macos": "bun build src/cli.ts --compile --target=bun-darwin-arm64 --outfile dist/fleet-darwin-arm64",
    "build:macos-intel": "bun build src/cli.ts --compile --target=bun-darwin-x64 --outfile dist/fleet-darwin-x64",
    "build:all": "bun run build && bun run build:linux && bun run build:windows && bun run build:macos && bun run build:macos-intel",
    "install-global": "bun run build && cp dist/fleet ~/.local/bin/fleet"
  },
  "keywords": [
    "ai",
    "agent",
    "workflow",
    "workspace",
    "git",
    "project",
    "cli",
    "development"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.3.2",
    "chalk": "^5.6.2",
    "commander": "^14",
    "defu": "^6.1.4",
    "fs-extra": "^11.3.3",
    "glob": "^13",
    "simple-git": "^3.20.0",
    "zod": "^4"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@semantic-release/exec": "^7.1.0",
    "@timobechtel/style": "^2.0.1",
    "@types/fs-extra": "^11.0.4",
    "bun-types": "^1.3.6",
    "eslint": "^9",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3"
  }
}
